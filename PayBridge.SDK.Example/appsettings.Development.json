{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },

  "PaymentGatewayConfig": {
    "EnabledGateways": [ "Paystack", "Flutterwave", "Stripe" ],

    "Paystack": {
      "PublicKey": "pk_test_YOUR_PAYSTACK_PUBLIC_KEY",
      "SecretKey": "sk_test_YOUR_PAYSTACK_SECRET_KEY"
    },

    "FlutterwaveConfig": {
      "PublicKey": "FLWPUBK_TEST-YOUR_FLUTTERWAVE_PUBLIC_KEY-X",
      "SecretKey": "FLWSECK_TEST-YOUR_FLUTTERWAVE_SECRET_KEY-X",
      "EncryptionKey": "YOUR_FLUTTERWAVE_ENCRYPTION_KEY"
    },

    "Stripe": {
      "SecretKey": "sk_test_YOUR_STRIPE_SECRET_KEY"
    }
  }
}
